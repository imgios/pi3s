{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":dependencyDashboard",
    ":pinDigests",
    ":separatePatchReleases"
  ],
  "timezone": "Europe/Rome",
  "dependencyDashboardTitle": "Dependency Dashboard 🤖",
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "automergeStrategy": "squash",
  "semanticCommits": "enabled",
  "separateMajorMinor": true,
  "branchPrefix": "renovate/update/",
  "rebaseWhen": "behind-base-branch",
  "commitMessagePrefix": "chore(deps):",
  "ignorePaths": [
    "**/*.md",
    "**/README*"
  ],
  "kubernetes": {
    "fileMatch": ["(^|/)kubernetes/.+\\.ya?ml$"]
  },
  "flux": {
    "fileMatch": ["(^|/)kubernetes/.+\\.ya?ml$"]
  },
  "helm-values": {
    "fileMatch": [
      "(^|/)kubernetes/.+values\\.ya?ml$",
       "(^|/)kubernetes/.+release\\.ya?ml$"
    ]
  },
  "packageRules": [
    {
      "description": "Group all Kubernetes image updates",
      "matchManagers": ["kubernetes"],
      "groupName": "k8s images"
    },
    {
      "description": "Separate infrastructure from apps",
      "matchPaths": ["kubernetes/infrastructure/**"],
      "groupName": "infrastructure"
    },
    {
      "description": "Separate apps updates",
      "matchPaths": ["kubernetes/apps/**"],
      "groupName": "apps"
    },
    {
      "description": "Automerge safe updates",
      "matchUpdateTypes": ["patch", "digest"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Delay non-patch updates for stability",
      "matchUpdateTypes": ["minor", "major"],
      "stabilityDays": 3
    }
  ]
}
